# .env.example
# Copy this file to .env.local and fill in the values

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# (Optional) Analytics or backend API endpoint
# NEXT_PUBLIC_API_URL=https://api.example.com

# Customizable Assets
# Set NEXT_PUBLIC_BANNER_URL to a custom banner image path or external URL
# Accepts relative paths (e.g. /my-banner.jpg) or absolute https:// URLs
# Falls back to /banner.jpg if not set or if the value is invalid
NEXT_PUBLIC_BANNER_URL=/banner.jpg

# Set NEXT_PUBLIC_LOGO_URL to a custom logo image path or external URL
# Accepts relative paths (e.g. /my-logo.svg) or absolute https:// URLs
# Falls back to /logo.svg if not set or if the value is invalid
NEXT_PUBLIC_LOGO_URL=/logo.svg
