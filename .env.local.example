# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Customizable Assets
# Set NEXT_PUBLIC_BANNER_URL to a custom banner image path or external URL
# Falls back to /banner.jpg if not set
NEXT_PUBLIC_BANNER_URL=/banner.jpg

# Set NEXT_PUBLIC_LOGO_URL to a custom logo image path or external URL
# Falls back to /logo.svg if not set
NEXT_PUBLIC_LOGO_URL=/logo.svg
