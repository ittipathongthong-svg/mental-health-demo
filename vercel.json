{\n  "version": 2,\n  "builds": [\n    {\n      "src": "next.config.js",\n      "use": "@vercel/next"\n    }\n  ],\n  "routes": [\n    {\n      "src": "/(.*)",\n      "dest": "/$1"\n    }\n  ],\n  "env": {\n    "API_URL": "https://api.example.com",\n    "NEXT_PUBLIC_CUSTOM_KEY": "your_custom_value"\n  },\n  "build": {\n    "env": {\n      "NEXT_BUILD_ENV": "production"\n    }\n  }\n}